<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:layout_width="350dp"
        android:layout_height="100dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="4dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp">

            <!-- FOOD IMAGE -->
            <ImageView
                android:id="@+id/imgFood"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="12dp"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:src="@tools:sample/avatars" />

            <!-- FOOD NAME -->
            <TextView
                android:id="@+id/tvFoodName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Herbal Pancake"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/imgFood"
                app:layout_constraintTop_toTopOf="@id/imgFood"
                app:layout_constraintEnd_toStartOf="@id/tvPrice" />

            <!-- CATEGORY -->
            <TextView
                android:id="@+id/menuCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="12sp"
                android:textColor="#777777"
                app:layout_constraintStart_toStartOf="@id/tvFoodName"
                app:layout_constraintTop_toBottomOf="@id/tvFoodName" />

            <!-- PRICE -->
            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="72dp"
                android:layout_height="28dp"
                android:layout_marginEnd="12dp"
                android:gravity="center"
                android:text="$7"
                android:textColor="@color/startColor"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/imgFood" />

            <!-- STATUS -->
            <TextView
                android:id="@+id/menuStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟢 Available"
                android:textSize="12sp"
                android:textColor="@android:color/holo_green_dark"
                app:layout_constraintStart_toStartOf="@id/menuCategory"
                app:layout_constraintTop_toBottomOf="@id/menuCategory" />

            <!-- ADD TO CART -->
            <TextView
                android:id="@+id/menuAddToCart"
                android:layout_width="96dp"
                android:layout_height="32dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/addtocartshape"
                android:elevation="4dp"
                android:gravity="center"
                android:text="Add To Cart"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ 0.0 (0)"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFA000"
                android:layout_marginTop="4dp"
                app:layout_constraintStart_toStartOf="@id/menuCategory"
                app:layout_constraintTop_toBottomOf="@id/menuStatus"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>