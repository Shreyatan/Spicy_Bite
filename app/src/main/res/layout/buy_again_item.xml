<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.cardview.widget.CardView
        android:id="@+id/recentCard"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginStart="8dp"
        app:layout_goneMarginTop="8dp"
        android:layout_marginEnd="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginBottom="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp">

            <!-- Image -->
            <ImageView
                android:id="@+id/recentImage"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:scaleType="centerCrop"
                android:src="@drawable/menu1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <!-- Food Name -->
            <TextView
                android:id="@+id/recentFoodName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="FoodName"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@id/recentImage"
                app:layout_constraintTop_toTopOf="@id/recentImage"
/>

            <!-- Price -->
            <TextView
                android:id="@+id/recentFoodPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$10"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="20sp"
                android:fontFamily="@font/yeonsung_regular"
                android:layout_marginTop="12dp"

                app:layout_constraintStart_toStartOf="@id/recentFoodName"
                app:layout_constraintTop_toBottomOf="@id/recentFoodName"/>
            <!-- Green Circle -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBuyAgain"
                android:layout_width="85dp"
                android:layout_height="30dp"
              android:layout_marginEnd="32dp"
                android:text="Buy Again"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="@font/yeonsung_regular"
                android:textAllCaps="false"
                android:background="@drawable/addtocartshape"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                />
            <!-- ⭐ Rate Now Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRateNow"
                android:layout_width="85dp"
                android:layout_height="28dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="32dp"
                android:background="@drawable/addtocartshape"
                android:fontFamily="@font/yeonsung_regular"
                android:text="⭐ Rate Now"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnBuyAgain" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>