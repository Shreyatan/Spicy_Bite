<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center">

    <androidx.cardview.widget.CardView
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="6dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <!-- IMAGE -->
            <ImageView
                android:id="@+id/menuImage"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:scaleType="centerCrop"
                android:layout_marginStart="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:src="@tools:sample/avatars" />

            <!-- FOOD NAME -->
            <TextView
                android:id="@+id/menuFoodName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Herbal Pancake"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@id/menuImage"
                app:layout_constraintTop_toTopOf="@id/menuImage"
                app:layout_constraintEnd_toStartOf="@id/menuPrice" />

            <!-- CATEGORY -->
            <TextView
                android:id="@+id/menuCategory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="12sp"
                android:textColor="#777777"
                android:layout_marginTop="4dp"
                app:layout_constraintStart_toStartOf="@id/menuFoodName"
                app:layout_constraintTop_toBottomOf="@id/menuFoodName"
                app:layout_constraintEnd_toStartOf="@id/menuPrice" />

            <!-- STATUS -->
            <TextView
                android:id="@+id/menuStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟢 Available"
                android:textSize="12sp"
                android:textColor="@android:color/holo_green_dark"
                android:layout_marginTop="4dp"
                app:layout_constraintStart_toStartOf="@id/menuCategory"
                app:layout_constraintTop_toBottomOf="@id/menuCategory" />

            <!-- PRICE -->
            <TextView
                android:id="@+id/menuPrice"
                android:layout_width="72dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="$7"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/startColor"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- ADD TO CART -->
            <TextView
                android:id="@+id/menuAddToCart"
                android:layout_width="96dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="Add To Cart"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/addtocartshape"
                android:layout_marginTop="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>