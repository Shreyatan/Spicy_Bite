<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- First Recent Buy Text -->
            <TextView
                android:id="@+id/textRecent1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Buy"
                android:fontFamily="@font/yeonsung_regular"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- Card Layout -->
            <androidx.cardview.widget.CardView
                android:id="@+id/recentCard"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/textRecent1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp">
                    app:cardCornerRadius="15dp"
                    <!-- Image -->
                    <ImageView
                        android:id="@+id/recentImage"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/menu1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>

                    <!-- Food Name -->
                    <TextView
                        android:id="@+id/recentFoodName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="FoodName"
                        android:fontFamily="@font/yeonsung_regular"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:layout_marginStart="12dp"
                        app:layout_constraintStart_toEndOf="@id/recentImage"
                        app:layout_constraintTop_toTopOf="@id/recentImage"
                        app:layout_constraintEnd_toStartOf="@id/orderestatus"/>

                    <!-- Price -->
                    <TextView
                        android:id="@+id/recentFoodPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$10"
                        android:fontFamily="@font/yeonsung_regular"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginTop="12dp"
                        app:layout_constraintStart_toStartOf="@id/recentFoodName"
                        app:layout_constraintTop_toBottomOf="@id/recentFoodName"/>
                    <!-- Green Circle -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/orderestatus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="32dp"
                        android:backgroundTint="#4CAF50"
                        app:cardCornerRadius="20dp"
                        app:layout_constraintBottom_toTopOf="@+id/appCompatButton"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                    </androidx.cardview.widget.CardView>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/receivedbutton"
                        android:layout_width="60dp"

                        android:layout_height="20dp"
                        android:background="@drawable/addtocartshape"
                        android:fontFamily="@font/yeonsung_regular"
                        android:text="Recieved"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="@+id/orderestatus"
                        app:layout_constraintStart_toStartOf="@+id/orderestatus"
                        app:layout_constraintTop_toBottomOf="@+id/orderestatus"
                        app:layout_constraintHorizontal_bias="0.5" />
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <!-- Second Recent Buy Text -->
            <TextView
                android:id="@+id/textRecent2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Buy"
                android:fontFamily="@font/yeonsung_regular"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/recentCard"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/buyAgainRecyclerView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/textRecent2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:listitem="@layout/buy_again_item"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</FrameLayout>